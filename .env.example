# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgresql://crowwire:crowwire@postgres:5432/crowwire

# Redis
REDIS_URL=redis://redis:6379

# RSSHub
RSSHUB_BASE_URL=http://rsshub:1200

# AI Model (Anthropic SDK)
ANTHROPIC_API_KEY=sk-ant-...
SCORING_MODEL=claude-haiku-4-5-20250315

# Queue Tuning
URGENT_FLUSH_INTERVAL_MS=30000
BATCH_FLUSH_INTERVAL_MS=600000
BATCH_FLUSH_COUNT_THRESHOLD=50
SCORER_CONCURRENCY=10
INGEST_CONCURRENCY=5
DELIVER_CONCURRENCY=3

# Scoring Thresholds
URGENT_SCORE_THRESHOLD=85

# OpenClaw
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_HOOKS_TOKEN=your-token-here
OPENCLAW_HOOKS_PATH=/hooks
OPENCLAW_DELIVERY_CHANNEL=last

# Summarization
SUMMARIZATION_MODEL=claude-sonnet-4-6-20250315
BATCH_SUMMARIZATION_THRESHOLD=20

# Dedup
DEDUP_TTL_HOURS=72
DEDUP_TITLE_BUCKET_MINUTES=30

# Content limits
MAX_CONTENT_SIZE_BYTES=102400
