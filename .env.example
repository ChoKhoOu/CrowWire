# LLM Configuration (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Discord Bot
DISCORD_BOT_TOKEN=
DISCORD_URGENT_CHANNEL_ID=
DISCORD_DIGEST_CHANNEL_ID=

# Runtime (all optional, shown with defaults)
FETCH_INTERVAL=20000
URGENT_FLUSH_INTERVAL=10000
URGENT_FLUSH_COUNT=5
DIGEST_FLUSH_INTERVAL=900000
URGENCY_THRESHOLD=75
SIMILARITY_THRESHOLD=0.55
DEDUP_TTL_HOURS=72
SENT_EVENT_TTL_HOURS=24
CONTENT_MAX_CHARS=500
MAX_ITEMS_PER_RUN=30

# Paths (Docker defaults)
DB_PATH=/app/data/crowwire.db
FEEDS_CONFIG=/app/feeds.yaml
TARGETS_CONFIG=/app/targets.yaml
FILTERS_CONFIG=/app/filters.yaml
